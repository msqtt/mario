# Shell MCP Server — Environment Variables
# Copy to .env and adjust as needed (never commit .env)

# Command allowlist: comma-separated command names, or * for all
ALLOWED_COMMANDS=*

# Command denylist: always enforced even when ALLOWED_COMMANDS=*
BLOCKED_COMMANDS=rm,dd,mkfs,fdisk,shred

# Filesystem access: comma-separated path prefixes
ALLOWED_PATHS=/tmp,/var/log,/home

# Default working directory for command execution
DEFAULT_CWD=/tmp

# Max execution time per command (seconds, 1-3600)
COMMAND_TIMEOUT_SECS=30

# Max stdout+stderr bytes returned (default 1 MB)
MAX_OUTPUT_BYTES=1048576

# Max POST body size accepted on the HTTP transport (bytes, 1-10485760)
MAX_REQUEST_BYTES=1048576

# Audit log file path (leave empty to log to stderr)
AUDIT_LOG_FILE=

# Transport: http (Streamable HTTP, MCP 2025-03-26) or stdio (local)
TRANSPORT=http

# HTTP bind host. Default 'localhost' (loopback only).
# To expose on the network, set a non-loopback host AND set API_KEY:
#   HTTP_HOST=0.0.0.0
#   API_KEY=$(openssl rand -hex 16)
HTTP_HOST=localhost
HTTP_PORT=8000

# Bearer token required on every HTTP request. Empty = no auth (loopback only).
API_KEY=

# Comma-separated env-var names to forward to spawned children, in addition to
# the safe defaults (PATH/HOME/LANG/...). Names matching KEY/TOKEN/SECRET/PASS/CRED
# are still dropped regardless. Use this for KUBECONFIG, NODE_PATH, etc.
EXTRA_ENV_PASSTHROUGH=
